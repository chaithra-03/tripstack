{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["busId", "operator", "layout", "decks"],
  "properties": {
    "busId": { "type": "string" },
    "operator": { "type": "string" },
    "layout": { "enum": ["deck"] },
    "decks": {
      "type": "object",
      "required": ["lower", "upper"],
      "properties": {
        "lower": { "$ref": "#/definitions/seats" },
        "upper": { "$ref": "#/definitions/seats" }
      }
    }
  },
  "definitions": {
    "seats": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["seatId", "deck", "kind", "state"],
        "properties": {
          "seatId": { "type": "string" },
          "deck": { "enum": ["lower", "upper"] },
          "kind": { "type": "string" },
          "state": { "enum": ["available", "booked", "held", "ladies", "occupied"] }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}

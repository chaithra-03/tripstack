{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["id", "pnr", "empId", "journeyType", "inventoryId", "state", "seatIds", "amountPaise", "refundable", "holdExpiresAt"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "pnr": { "type": ["string", "null"] },
    "empId": { "type": "string" },
    "journeyType": { "enum": ["bus"] },
    "inventoryId": { "type": "string" },
    "state": { "enum": ["HELD", "PAYMENT_PENDING", "CONFIRMED", "CANCELLED", "REFUNDED"] },
    "seatIds": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "amountPaise": { "type": "integer", "minimum": 0 },
    "refundable": { "type": "boolean" },
    "holdExpiresAt": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": true
}

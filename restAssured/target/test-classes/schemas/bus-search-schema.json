{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["from", "to", "date", "count", "buses"],
  "properties": {
    "from": { "type": "string" },
    "to": { "type": "string" },
    "date": { "type": "string", "format": "date" },
    "count": { "type": "integer", "minimum": 0 },
    "buses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "operator", "operatorName", "kind", "origin", "dest", "depTime", "arrTime", "baseFarePaise", "taxPaise", "farePaise", "seatsLeft"],
        "properties": {
          "id": { "type": "string" },
          "operator": { "type": "string" },
          "operatorName": { "type": "string" },
          "kind": { "type": "string" },
          "origin": { "type": "string" },
          "dest": { "type": "string" },
          "depTime": { "type": "string" },
          "arrTime": { "type": "string" },
          "baseFarePaise": { "type": "integer", "minimum": 0 },
          "taxPaise": { "type": "integer", "minimum": 0 },
          "farePaise": { "type": "integer", "minimum": 0 },
          "seatsLeft": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
